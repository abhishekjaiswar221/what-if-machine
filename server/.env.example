GEMINI_API_KEY=your-api-key-here
# If your local Mongo user is a root/admin user, add ?authSource=admin
MONGODB_URI=mongodb://root:root@localhost:27017/what-if-machine?authSource=admin
PORT=5000
# Only needed in dev, when the Vite client (port 5173) is a different origin
# from this server. Leave unset in prod where this server serves the built
# client itself (same-origin, no CORS required).
CLIENT_ORIGIN=http://localhost:5173
